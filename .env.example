# PocketBase server URL (defaults to http://127.0.0.1:8090 if unset)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Mapbox access token (required)
# 1. Sign up for a free Mapbox account at https://account.mapbox.com/
# 2. Copy your default public token (starts with 'pk.')
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Custom Mapbox Studio styles for the light and dark themes (optional).
# Create them by following plans/subtasks/1.4-mapbox-studio-instructions.md,
# then paste the published style URLs here. If unset, stock Mapbox styles
# are used (outdoors-v12 for light, dark-v11 for dark).
VITE_MAPBOX_STYLE_LIGHT=mapbox://styles/your_username/your_light_style_id
VITE_MAPBOX_STYLE_DARK=mapbox://styles/your_username/your_dark_style_id

# Custom Mapbox Studio satellite style (optional, single style for both
# themes). Create it by following the recipe in
# plans/subtasks/3.9-satellite-mode.md, then paste the published style URL
# here. If unset, the stock satellite-streets-v12 style is used.
VITE_MAPBOX_STYLE_SATELLITE=mapbox://styles/your_username/your_satellite_style_id
